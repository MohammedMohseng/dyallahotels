generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  RECEPTIONIST
  ACCOUNTANT
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  CLEANING
  MAINTENANCE
  RESERVED
}

enum RoomType {
  SINGLE
  DOUBLE
  TWIN
  SUITE
  DELUXE
  FAMILY
}

enum StayStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PAID
  PARTIAL
  UNPAID
  OVERDUE
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  MOBILE_PAYMENT
  CARD
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  CHECKED_IN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(RECEPTIONIST)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  payments Payment[]
}

model Room {
  id            String     @id @default(cuid())
  roomNumber    String     @unique
  floor         Int
  type          RoomType   @default(SINGLE)
  capacity      Int        @default(1)
  pricePerNight Float
  status        RoomStatus @default(AVAILABLE)
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  stays       Stay[]
  reservations Reservation[]
}

model Guest {
  id             String   @id @default(cuid())
  fullName       String
  phone          String
  nationality    String?
  passportNumber String?  @unique
  nationalId     String?
  gender         Gender?
  companyId      String?
  notes          String?
  passportImage  String?
  createdAt      DateTime @default(now())

  company      Company?  @relation(fields: [companyId], references: [id])
  stays        Stay[]
  reservations Reservation[]
}

model Company {
  id            String   @id @default(cuid())
  name          String
  contactPerson String?
  phone         String?
  address       String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  guests Guest[]
}

model Stay {
  id             String         @id @default(cuid())
  guestId        String
  roomId         String
  checkIn        DateTime
  expectedCheckOut DateTime
  actualCheckOut  DateTime?
  numberOfGuests Int            @default(1)
  totalPrice     Float
  amountPaid     Float          @default(0)
  paymentStatus  PaymentStatus  @default(UNPAID)
  status         StayStatus     @default(ACTIVE)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  guest    Guest     @relation(fields: [guestId], references: [id])
  room     Room      @relation(fields: [roomId], references: [id])
  payments Payment[]

  @@index([guestId])
  @@index([roomId])
  @@index([status])
}

model Reservation {
  id          String            @id @default(cuid())
  guestId     String
  roomId      String
  startDate   DateTime
  endDate     DateTime
  deposit     Float             @default(0)
  status      ReservationStatus @default(PENDING)
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  guest Guest @relation(fields: [guestId], references: [id])
  room  Room  @relation(fields: [roomId], references: [id])

  @@index([guestId])
  @@index([roomId])
  @@index([status])
}

model Payment {
  id            String        @id @default(cuid())
  stayId        String
  amount        Float
  paymentMethod PaymentMethod
  receivedBy    String
  notes         String?
  createdAt     DateTime      @default(now())

  stay Stay @relation(fields: [stayId], references: [id])
  user User @relation(fields: [receivedBy], references: [id])

  @@index([stayId])
}
